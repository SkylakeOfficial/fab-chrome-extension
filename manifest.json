{
  "manifest_version": 3,
  "name": "Fab Content Downloader",
  "version": "0.2.0",
  "description": "Download your Fab.com Unreal Engine content without the Epic Games Launcher.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.epicgames.com/*",
    "https://account-public-service-prod03.ol.epicgames.com/*",
    "https://www.fab.com/*",
    "https://egdownload.fastly-edge.com/*",
    "https://epicgames-download1.akamaized.net/*",
    "https://egs-cloudfront-chunks.epicgamescdn.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.epicgames.com/id/api/redirect*"],
      "js": ["content/oauth-capture.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Fab Downloader"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+F"
      }
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
